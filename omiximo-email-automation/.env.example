# ==============================================
# Omiximo Email-to-Inventory Automation
# ==============================================
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control!

# ----------------------------------------------
# IMAP Email Settings (Hostnet)
# ----------------------------------------------
IMAP_SERVER=imap.hostnet.nl
IMAP_PORT=993
IMAP_EMAIL=info@omiximo.nl
IMAP_PASSWORD=your_email_password_here
IMAP_USE_SSL=true

# ----------------------------------------------
# InvenTree API Settings
# ----------------------------------------------
# Use container name when running in Docker network
INVENTREE_API_URL=http://inventree-server:8000/api
INVENTREE_API_TOKEN=your_inventree_api_token_here

# Alternative: username/password auth (if not using token)
# INVENTREE_USERNAME=admin
# INVENTREE_PASSWORD=your_password

# ----------------------------------------------
# Component SKU Mapping
# ----------------------------------------------
# RAM modules (required)
RAM_8GB_SKU=RAM-8GB-DDR4
RAM_16GB_SKU=RAM-16GB-DDR4

# SSD drives (optional - set to empty to skip)
SSD_256GB_SKU=SSD-256GB-NVME
SSD_512GB_SKU=SSD-512GB-NVME
SSD_1TB_SKU=SSD-1TB-NVME
SSD_2TB_SKU=SSD-2TB-NVME

# CPUs (optional - uses SKU pattern matching if not set)
# CPU_R3_SKU=CPU-RYZEN3
# CPU_R5_SKU=CPU-RYZEN5
# CPU_R7_SKU=CPU-RYZEN7

# GPUs (optional - uses SKU pattern matching if not set)
# GPU_RTX3050_SKU=GPU-RTX3050
# GPU_RTX5050_SKU=GPU-RTX5050
# GPU_RTX5060_SKU=GPU-RTX5060

# ----------------------------------------------
# Timezone
# ----------------------------------------------
TZ=Europe/Amsterdam

# ----------------------------------------------
# Logging (optional)
# ----------------------------------------------
LOG_LEVEL=INFO
