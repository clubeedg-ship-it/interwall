# Omiximo Inventory OS — Environment Variables
# Copy to .env and fill in values before running docker compose up

# PostgreSQL password (used in DATABASE_URL)
POSTGRES_PASSWORD=change_me_before_production

# Session cookie signing secret — MUST be at least 32 characters
SESSION_SECRET=change-me-in-production-min-32-chars-xxxxxxxx

# Frontend port (default: 1441)
FRONTEND_PORT=1441
