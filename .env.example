# Interwall Inventory OS — Environment Variables
# Copy to .env and fill in values before running docker compose up --build

# Runtime mode
APP_ENV=development

# PostgreSQL password (required)
POSTGRES_PASSWORD=change_me_before_production

# Session cookie signing secret — MUST be at least 32 characters
SESSION_SECRET=change-me-in-production-min-32-chars-xxxxxxxx
SESSION_HTTPS_ONLY=false

# IMAP poller (leave blank to disable email polling)
IMAP_SERVER=
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_EMAIL=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# Frontend port (default: 1441)
FRONTEND_PORT=1441

# Bol.com Retailer API v10 (leave empty to disable Bol.com polling)
BOL_CLIENT_ID=
BOL_CLIENT_SECRET=
BOL_POLL_INTERVAL_MINUTES=10
BOL_CHANGE_INTERVAL_MINUTES=15
